{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "strict": true,
    "paths": {
      "scenerystack": ["./node_modules/scenerystack/dist/prod/index.d.ts"],
      "scenerystack/*": ["./node_modules/scenerystack/dist/prod/*.d.ts"]
    }
  },
  "include": ["src"]
}
